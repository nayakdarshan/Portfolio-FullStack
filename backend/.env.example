# Backend Environment Variables — copy this to backend/.env
NODE_ENV=production
PORT=3000

# MongoDB Atlas connection string
MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/portfolio?retryWrites=true&w=majority

# JWT Secret — generate a strong random string
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# Frontend origin (for CORS)
FRONTEND_URL=https://your-portfolio-domain.com

# Upload directory (relative to backend/)
UPLOAD_DIR=uploads
